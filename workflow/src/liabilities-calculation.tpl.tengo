self := import("@platforma-sdk/workflow-tengo:tpl")
smart := import("@platforma-sdk/workflow-tengo:smart")
ll := import("@platforma-sdk/workflow-tengo:ll")
exec := import("@platforma-sdk/workflow-tengo:exec")
assets := import("@platforma-sdk/workflow-tengo:assets")
text := import("text")
json := import("json")

liabilitiesCalcSw := assets.importSoftware("@platforma-open/milaboratories.antibody-sequence-liabilities.liabilities-calc-script:main")

self.defineOutputs("result", "newMapping", "regionsFound")


self.body(func(args) {

	inputTable := args.table
    mapping := args.mapping
	numberingSchema := args.numberingSchema
	customLiabilities := args.customLiabilities
	usePredefinedLiabilities := args.usePredefinedLiabilities
	disabledPredefinedLiabilities := args.disabledPredefinedLiabilities

    // Run the liabilities calculation tool on the sequences
	liabilitiesCalcCmd := exec.builder().
		software(liabilitiesCalcSw).
		mem("16GiB").
		cpu(1).
		addFile("input.tsv", inputTable). // Use the built file
		arg("input.tsv").
		arg("result.tsv").
		saveFile("result.tsv").
		arg("-o").arg("output.json").
		saveFileContent("output.json").
		arg("--output-regions-found").arg("regions-found.json").
		saveFileContent("regions-found.json")

	if mapping {
		liabilitiesCalcCmd.arg("-m").arg(mapping)
	}

	if numberingSchema {
		liabilitiesCalcCmd.arg("--numbering-schema").arg(numberingSchema)
	}

	if customLiabilities && len(customLiabilities) > 0 {
		liabilitiesCalcCmd.writeFile("custom-liabilities.json", json.encode(customLiabilities))
		liabilitiesCalcCmd.arg("--custom-liabilities").arg("custom-liabilities.json")
	}

	if usePredefinedLiabilities != undefined {
		liabilitiesCalcCmd.arg("--use-predefined-liabilities").arg(string(usePredefinedLiabilities))
	}

	if disabledPredefinedLiabilities && len(disabledPredefinedLiabilities) > 0 {
		liabilitiesCalcCmd.writeFile("disabled-predefined-liabilities.json", json.encode(disabledPredefinedLiabilities))
		liabilitiesCalcCmd.arg("--disabled-predefined-liabilities").arg("disabled-predefined-liabilities.json")
	}

	liabilitiesResult := liabilitiesCalcCmd.run()

	result := liabilitiesResult.getFile("result.tsv")
	
	newMapping := liabilitiesResult.getFileContent("output.json")

	regionsFound := liabilitiesResult.getFileContent("regions-found.json")

    return {
        result: result,
        newMapping: newMapping,
		regionsFound: regionsFound
    }
	
	
})